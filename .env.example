# Copy to .env.local and fill in values

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/studio_portal

# Required: Better Auth secret (signs/encrypts session tokens).
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET

# Required: public origin used to build magic-link callback URLs (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# Email (Resend). Optional in dev — magic links are logged to the console.
# Required in production to actually send mail.
RESEND_API_KEY=
EMAIL_FROM=Studio Portal <onboarding@resend.dev>

# Running the integration test suite? See .env.test.example — TEST_DATABASE_URL is a
# separate, deliberately isolated config surface (must NOT equal DATABASE_URL above).
