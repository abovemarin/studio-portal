# Integration test database (7.1 harness).
#
# A REAL, THROWAWAY Postgres whose database name MUST end in "_test". The harness truncates every
# table between tests, so NEVER point this at your dev/seed database — the safety rail refuses to run
# if the name doesn't end in _test or if it equals DATABASE_URL.
#
# Copy this file to .env.test.local (gitignored) and fill in your connection string. In CI the
# postgres services container supplies TEST_DATABASE_URL instead.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studio_portal_test
